<?xml version="1.0" encoding="utf-8"?>
<!-- Основной контейнер экрана с синим системным фоном -->
<RelativeLayout xmlns:android="http://android.com"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2196F3">

    <!-- Белая карточка мастера настройки, имитирующая окно -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_maxWidth="420dp"
        android:layout_centerInParent="true"
        android:background="#FFFFFF"
        android:elevation="4dp"
        android:orientation="vertical">

        <!-- СТРОГАЯ ОДНОТОННАЯ ШАПКА -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2196F3"
            android:orientation="vertical"
            android:paddingLeft="24dp"
            android:paddingTop="40dp"
            android:paddingRight="24dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/setup_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Заголовок отчета"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                fontFamily="sans-serif" />

            <TextView
                android:id="@+id/setup_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.85"
                android:text="Краткое описание или период данных"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                fontFamily="sans-serif" />
        </LinearLayout>

        <!-- ОСНОВНОЙ КОНТЕНТ (СКРОЛЛИРУЕМЫЙ) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Блок текстовой информации 1 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Основная информация"
                    android:textColor="#2196F3"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/info_text_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.3"
                    android:text="Сюда вы можете вставить любой текст описания. Шаблон использует стандартные системные шрифты и отступы Android."
                    android:textColor="#212121"
                    android:textSize="16sp"
                    fontFamily="sans-serif" />

                <!-- Тонкий системный разделитель (Divider) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_bottom="20dp"
                    android:background="#E0E0E0" />

                <!-- БЛОК ПРОЦЕНТОВ И ИНДИКАТОРА -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Текущий показатель"
                    android:textColor="#2196F3"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    fontFamily="sans-serif-medium" />

                <!-- Серая подложка для блока с процентами -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Крупное текстовое значение процента -->
                    <TextView
                        android:id="@+id/percentage_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="75%"
                        android:textColor="#212121"
                        android:textSize="56sp"
                        fontFamily="sans-serif-light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="4dp"
                        android:text="Доля выполнения поставленной задачи"
                        android:textColor="#757575"
                        android:textSize="14sp"
                        fontFamily="sans-serif" />

                    <!-- Горизонтальная линия прогресса (Progress Bar) -->
                    <ProgressBar
                        android:id="@+id/progress_bar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:max="100"
                        android:progress="75"
                        android:progressTint="#2196F3" />
                </LinearLayout>

                <!-- Еще один разделитель -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:layout_bottom="20dp"
                    android:background="#E0E0E0" />

                <!-- Блок текстовой информации 2 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Дополнительные сведения"
                    android:textColor="#2196F3"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/info_text_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Любые сопутствующие данные, примечания или системные сноски для пользователя."
                    android:textColor="#212121"
                    android:textSize="16sp"
                    fontFamily="sans-serif" />

            </LinearLayout>
        </ScrollView>

        <!-- НИЖНЯЯ ПАНЕЛЬ С КНОПКАМИ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:borderTop="1dp"
            android:backgroundTint="#FFFFFF">

            <!-- Кнопка Назад (плоская, серая) -->
            <Button
                android:id="@+id/btn_back"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Назад"
                android:textColor="#757575"
                android:textSize="14sp" />

            <!-- Пружина-разделитель, чтобы сдвинуть вторую кнопку вправо -->
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

            <!-- Кнопка Далее (акцентная синяя) -->
            <Button
                android:id="@+id/btn_next"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Далее"
                android:textColor="#2196F3"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
